tipe_zakat = input("Mau hitung zakat apa(emas,perak,uang)")
#uang
if tipe_zakat.lower() == "uang":
    uang_anda = float(input("Berapa   uang anda?")) 
    harga_uang = float(input("Berapa  harga perak sekarang?"))
    if uang_anda >= 595 * harga_uang: 
        zakat_uang = uang_anda / 40
        print("Zakat anda: Rp",                      zakat_uang)
    else: print("Ga Usah Bayar Zakat")
